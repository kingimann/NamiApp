# Replit configuration — tells Replit how to run the Nampo backend.
run = "cd backend && pip install -r requirements.txt && uvicorn server:app --host 0.0.0.0 --port $PORT --reload"
modules = ["python-3.11", "postgresql-16", "nodejs-20"]

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 5000
externalPort = 80

[env]
# Replit provides $PORT at runtime; the app binds to it.
PORT = "8080"
DB_NAME = "nampo"
CORS_ORIGINS = "*"
# Do NOT put MONGO_URL here. Add it as a Secret (lock icon) so it stays private.

[nix]
channel = "stable-23_11"

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start frontend"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && pip install -r requirements.txt -q && uvicorn server:app --host 0.0.0.0 --port 8080"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Start frontend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && EXPO_PUBLIC_BACKEND_URL=https://3eaa8c9d-23d4-47c8-b4a7-519fe26eef5c-00-1if31mt60e650.worf.replit.dev npx expo start --web --port 5000"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"
