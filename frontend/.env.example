# Frontend environment variables (Expo).
# Copy this to `.env.local` and fill in your values, then RESTART Metro.
#
# IMPORTANT: anything prefixed with EXPO_PUBLIC_ is inlined into the JS bundle at
# build time. Changing one requires restarting the dev server, and for a custom
# dev/production build (not Expo Go) you must REBUILD the native app for native
# modules and new values to take effect — a Fast-Refresh reload is not enough.

# Backend API base URL (the client calls this + "/api"). On web it can fall back
# to same-origin via the Metro proxy, but native always needs the full URL.
EXPO_PUBLIC_BACKEND_URL=http://localhost:8080

# Mapbox access token — REQUIRED for the map, directions, and geocoding to render.
# Without it MapboxWebView shows a "Map unavailable" message instead of a map.
# Get one at https://account.mapbox.com/access-tokens/
EXPO_PUBLIC_MAPBOX_TOKEN=

# Cloudinary (media uploads / CDN)
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=
EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# Tenor (GIF picker)
EXPO_PUBLIC_TENOR_KEY=

# Stripe publishable key (in-app card payments)
EXPO_PUBLIC_STRIPE_KEY=
